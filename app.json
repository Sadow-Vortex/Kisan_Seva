{
  "expo": {
    "name": "Kisan Seva",
    "slug": "kisan-seva",
    "version": "1.1.2",
    "icon": "./assets/images/Logo.png",
    "orientation": "portrait",
    "scheme": "login",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyAFJMgs61N9l4wckoqdC1M2XcA652h-tBU"
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAFJMgs61N9l4wckoqdC1M2XcA652h-tBU"
        }
      },
      "package": "com.kisanseva.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "sadow_vortex",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf92640e-c1b5-4634-8501-a4d1d5483ddd"
      }
    }
  }
}
